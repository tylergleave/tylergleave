# Cloudflare Turnstile
# Get these from https://dash.cloudflare.com -> Turnstile
PUBLIC_TURNSTILE_SITE_KEY=your_site_key_here   # shown in widget code snippet
TURNSTILE_SECRET_KEY=your_secret_key_here       # keep this server-side only

# Mailgun
# Get these from https://app.mailgun.com -> Sending -> Domains
MAILGUN_API_KEY=your_mailgun_api_key_here       # API key (not the signing key)
MAILGUN_DOMAIN=mg.tylergleave.com                # your sending domain
